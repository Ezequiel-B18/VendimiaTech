# Copernicus Data Space (Sentinel-2)
# Regenerar en: dataspace.copernicus.eu
COPERNICUS_CLIENT_ID=sh-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
COPERNICUS_CLIENT_SECRET=your-secret-here

# Google Gemini
# Obtener en: aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key-here

# Email alerts (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
ALERTS_FROM_EMAIL=alertas@tu-dominio.com

# Blockchain — BNB Chain (BSC Testnet)
NEXT_PUBLIC_BSC_RPC=https://data-seed-prebsc-1-s1.binance.org:8545
NEXT_PUBLIC_CONTRACT_BSC=0x5ef76b92F4BF935866Ae6de275173Dd5DDE42Fb6

# Blockchain — Rootstock (RSK Testnet)
# Deploy: npx hardhat run contracts/deploy.ts --network rskTestnet
# Faucet: faucet.rootstock.io
NEXT_PUBLIC_RSK_RPC=https://public-node.testnet.rsk.co
NEXT_PUBLIC_CONTRACT_RSK=0x...

# Private key del deployer (para modo Rápido server-side)
DEPLOYER_PRIVATE_KEY=0x...

# Hedera
HEDERA_ACCOUNT_ID=0.0.xxxxx
HEDERA_PRIVATE_KEY=your-hedera-private-key
HEDERA_TOPIC_ID=0.0.xxxxx

# Stellar Soroban
NEXT_PUBLIC_STELLAR_RPC=https://soroban-testnet.stellar.org
NEXT_PUBLIC_STELLAR_CONTRACT=your-stellar-contract-address
STELLAR_SECRET_KEY=your-stellar-secret-key

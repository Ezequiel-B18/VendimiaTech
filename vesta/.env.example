# ============================================================
# VESTA — Variables de entorno
# Copiar a .env.local y completar los valores reales
# ============================================================

# Copernicus Data Space (Sentinel-2)
# Regenerar en: https://dataspace.copernicus.eu/ → User Settings → OAuth
COPERNICUS_CLIENT_ID=sh-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
COPERNICUS_CLIENT_SECRET=

# Google Gemini 2.5 Flash
# Obtener en: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Blockchain — RPCs públicos (no cambiar para testnet)
NEXT_PUBLIC_BSC_RPC=https://data-seed-prebsc-1-s1.binance.org:8545
NEXT_PUBLIC_RSK_RPC=https://public-node.testnet.rsk.co

# Contrato VESTA deployado (completar después del deploy)
NEXT_PUBLIC_CONTRACT_ADDRESS=

# Hedera Testnet
# Crear cuenta en: https://portal.hedera.com/
HEDERA_ACCOUNT_ID=0.0.XXXXXX
HEDERA_PRIVATE_KEY=
HEDERA_TOPIC_ID=0.0.XXXXXX

# Wallet deployer (solo para hardhat deploy — nunca exponer en frontend)
# Faucets: https://testnet.bnbchain.org/faucet-smart | https://faucet.rootstock.io
DEPLOYER_PRIVATE_KEY=
